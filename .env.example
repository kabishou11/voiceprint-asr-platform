APP_ENV=development
APP_NAME=voiceprint-asr-platform
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_PORT=5173
ASYNC_MODE=auto
# 默认禁止创建任务接口在 API 线程内同步执行真实 ASR/多人转写，避免前端卡在“创建任务”并拖慢全站。
# 仅本地调试小音频时可改为 1。
ALLOW_SYNC_TRANSCRIPTION_FALLBACK=0
# Windows 本地开发建议 solo，避免 Celery/billiard 多进程 semaphore 权限错误。
# Linux/容器可删除或改为 prefork/threads，并按显存调 CELERY_WORKER_CONCURRENCY。
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1

# 复制本文件为 .env 后再启动。
# 当前项目强制要求本地模型 + CUDA GPU 同时就绪，否则高精度 ASR / 多人分离 / 声纹任务会直接拒绝执行。

POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/voiceprint
REDIS_DSN=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voiceprint-assets

# 所有模型都必须放在仓库根目录 models/ 下。
FUNASR_MODEL=models/Fun-ASR-Nano-2512
THREE_D_SPEAKER_MODEL=models/3D-Speaker/campplus
PYANNOTE_MODEL=models/pyannote/speaker-diarization-community-1

# pyannote 官方离线包需要 Hugging Face gated 权限；默认关闭。
ENABLE_PYANNOTE=false

# 3D-Speaker 自适应聚类仍属于实验能力；当前默认关闭，避免把未稳定优于 v18 的策略直接作为主链路默认值。
ENABLE_3D_SPEAKER_ADAPTIVE_CLUSTERING=false

# 8GB 显存默认使用 auto：空闲显存足够才并行 ASR + diarization，否则串行避免 OOM。
PARALLEL_ASR_DIARIZATION=auto
MIN_PARALLEL_FREE_GPU_MB=10000

# 会议纪要 LLM。兼容 OpenAI Chat Completions 协议；未配置 API KEY 时仅使用本地规则纪要。
# 也兼容 OPENAI_API_KEY / OPENAI_BASE_URL，便于接入 OpenAI-compatible 网关或 MiniMax 代理。
MINUTES_LLM_API_KEY=
MINUTES_LLM_BASE_URL=https://api.minimax.chat/v1
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.minimax.chat/v1
MINUTES_LLM_MODEL=MiniMax-M2.7
MINUTES_LLM_REASONING_SPLIT=true
MINUTES_LLM_TIMEOUT_SECONDS=90
