APP_ENV=development
APP_NAME=voiceprint-asr-platform
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_PORT=5173

# 复制本文件为 .env 后再启动。
# 当前项目强制要求本地模型 + CUDA GPU 同时就绪，否则高精度 ASR / 多人分离 / 声纹任务会直接拒绝执行。

POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/voiceprint
REDIS_DSN=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voiceprint-assets

# 所有模型都必须放在仓库根目录 models/ 下。
FUNASR_MODEL=models/Fun-ASR-Nano-2512
THREE_D_SPEAKER_MODEL=models/3D-Speaker/campplus
PYANNOTE_MODEL=models/pyannote/speaker-diarization-community-1

# pyannote 官方离线包需要 Hugging Face gated 权限；默认关闭。
ENABLE_PYANNOTE=false
